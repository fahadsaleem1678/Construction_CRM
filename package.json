{
  "name": "construction-crm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev:api": "pnpm --filter @construction-crm/api dev",
    "dev:web": "pnpm --filter @construction-crm/web dev",
    "db:migrate": "pnpm --filter @construction-crm/api prisma:migrate",
    "db:seed": "pnpm --filter @construction-crm/api prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@11.7.0"
}
